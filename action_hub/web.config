<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config for ActionHub using HttpPlatformHandler.

  WHY THIS FILE:
    IIS owns the process. When the site receives its first request after a
    reboot, IIS launches python.exe + wsgi.py. If the process exits, IIS
    restarts it automatically. No watchdog, no Startup-folder shortcut,
    no manual launch ever again.

  PREREQUISITES (one-time, done in IIS Manager by an admin):
    1. Install IIS feature "Web Server (IIS)" with "CGI" sub-feature.
       (Server Manager -> Add Roles and Features.)
    2. Install "HttpPlatformHandler 1.2" from
       https://www.iis.net/downloads/microsoft/httpplatformhandler
    3. In IIS Manager:
         - Add Website
             Site name:        ActionHub
             Physical path:    C:\Users\leung\Documents\GitHub\actionhub\action_hub
             Binding:          http, port 80 (or 5000), all unassigned
         - Make sure the Application Pool identity has READ access to the
           physical path and READ/WRITE on:
               action_hub\db\
               action_hub\attachments\
               action_hub\flask_session\
               logs\
    4. Place this file as:
           C:\Users\leung\Documents\GitHub\actionhub\action_hub\web.config

  TEST:
    Browse to  http://localhost/   (or your chosen port)
    First request will spawn python; check logs\iis_stdout*.log for boot
    messages.
-->
<configuration>
  <system.webServer>

    <handlers>
      <!-- Send ALL requests to the Python process spawned by HttpPlatformHandler -->
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <!--
      processPath  : full path to the venv python.exe
      arguments    : path to wsgi.py (waitress is launched inside wsgi.py)
      stdoutLogEnabled / stdoutLogFile : capture Python stdout+stderr
      startupTimeLimit : seconds IIS waits for the app to start listening
      requestTimeout   : per-request timeout (hh:mm:ss)
      %HTTP_PLATFORM_PORT% is set by IIS; the app MUST bind to it.
    -->
    <httpPlatform
        processPath="C:\apps\actionhub\.venv\Scripts\python.exe"
        arguments="C:\apps\actionhub\action_hub\wsgi.py"
        stdoutLogEnabled="true"
        stdoutLogFile="C:\apps\actionhub\logs\iis_stdout"
        startupTimeLimit="60"
        startupRetryCount="3"
        requestTimeout="00:04:00">
      <environmentVariables>
        <!-- IIS-injected port. wsgi.py already reads %PORT% -->
        <environmentVariable name="PORT"    value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOST"    value="127.0.0.1" />
        <environmentVariable name="THREADS" value="8" />
        <!-- Make sure Python can import the app package -->
        <environmentVariable name="PYTHONPATH" value="C:\apps\actionhub\action_hub" />
        <!-- Force unbuffered output so stdout log is live -->
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
